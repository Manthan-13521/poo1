# ── Core ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname
NEXT_PUBLIC_APP_URL=https://yourapp.com
NEXTAUTH_URL=https://yourapp.com

# Generate with: openssl rand -base64 64
NEXTAUTH_SECRET=

# ── Security ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SEED_SECRET=
CRON_SECRET=

# ── Cloudinary (photo & QR storage) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Twilio (WhatsApp reminders) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Razorpay (Online payments) ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Super Admin Seed ───────────────────────────────────────────────────
# Credentials for the platform superadmin (seeded via /api/seed)
SUPER_ADMIN_EMAIL=superadmin@yourapp.com
SUPER_ADMIN_PASSWORD=

# ── Upstash Redis (rate limiting, caching — optional for dev) ──────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AWS S3 (Database Backups) ─────────────────────────────────────────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
